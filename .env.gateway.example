# Variables for the Discord Gateway worker (Railway / Render / local).
# Copy to Railway service env — NOT the full Vercel set.

# URL pública de la app Next.js en Vercel (sin / al final)
NEXT_PUBLIC_APP_URL=https://discord-poc-ten.vercel.app

DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_CLIENT_ID=

# Mismo Redis que Vercel (Upstash) — estado del Chat SDK
REDIS_URL=

# Opcional
DISCORD_BOT_USERNAME=flywheel
GATEWAY_LISTENER_MS=86400000
