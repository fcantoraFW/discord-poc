# App (required in production — your public HTTPS origin, no trailing slash)
# Vercel also auto-detects VERCEL_URL if this is unset or still localhost
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — https://supabase.com/dashboard/project/_/settings/api
# API URL (Settings → API). Must include https://
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable or legacy anon key (same variable name for both)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=  # optional alias
SUPABASE_SERVICE_ROLE_KEY=

# Cursor Cloud — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
# GitHub repo for cloud agents (owner/repo or full https URL)
CURSOR_CLOUD_REPO=your-org/discord-poc
# Branch name passed as startingRef (default: main). Must be a branch name, not a commit SHA.
CURSOR_CLOUD_REF=main

# Discord — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
# Secret for GET /api/discord/gateway (GitHub Actions, cron-job.org, or Vercel Pro cron)
CRON_SECRET=
# Optional: Gateway HTTP route limits (Hobby Vercel ≈ 10s max)
# GATEWAY_MAX_DURATION=10
# GATEWAY_LISTENER_MS=9000
# Worker: pnpm discord:gateway (long-lived; set GATEWAY_LISTENER_MS=86400000)
DISCORD_BOT_USERNAME=flywheel
# Optional: permission integer for bot invite (default 117760)
DISCORD_BOT_PERMISSIONS=117760

# Redis (Fase 2 — Chat SDK state). Upstash provides a rediss:// URL.
REDIS_URL=
# Alias supported by the app:
UPSTASH_REDIS_URL=
