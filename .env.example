# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — https://supabase.com/dashboard/project/_/settings/api
# API URL (Settings → API). Must include https://
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable or legacy anon key (same variable name for both)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=  # optional alias
SUPABASE_SERVICE_ROLE_KEY=

# Cursor Cloud — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
# GitHub repo for cloud agents (owner/repo or full https URL)
CURSOR_CLOUD_REPO=your-org/discord-poc

# Discord — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_USERNAME=flywheel
# Optional: permission integer for bot invite (default 117760)
DISCORD_BOT_PERMISSIONS=117760

# Redis (Fase 2 — Chat SDK state). Upstash provides a rediss:// URL.
REDIS_URL=
# Alias supported by the app:
UPSTASH_REDIS_URL=
